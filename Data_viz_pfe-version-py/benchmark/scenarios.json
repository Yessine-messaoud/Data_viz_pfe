      ]
    },
    "question": "Pour chaque colonne, measure ou dimension et type metier ?",
    "expected": {
      "column_expectations": {
        "Amt": "measure",
        "Value": "measure",
        "X1": "dimension",
        "Region": "dimension",
        "OrderDate": "dimension"
      }
    }
  },
  {
    "id": "phase3_visual_mapping",
