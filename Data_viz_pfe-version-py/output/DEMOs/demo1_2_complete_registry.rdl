  <DataSets>
    <DataSet Name="federated_1v3o2r30w2rgsv1aei9is1e9duvo">
      <Query>
        <DataSourceName>DataSource1</DataSourceName>
        <CommandText>SELECT st.SalesTerritoryCountry AS SalesTerritoryCountry, p.ModelName AS ModelName, f.SalesAmount AS SalesAmount, f.TaxAmt AS TaxAmt, f.OrderQuantity AS OrderQuantity FROM dbo.FactInternetSales AS f INNER JOIN dbo.DimSalesTerritory AS st ON f.SalesTerritoryKey = st.SalesTerritoryKey INNER JOIN dbo.DimProduct AS p ON f.ProductKey = p.ProductKey</CommandText>
      </Query>
      <Fields>
        <Field Name="SalesAmount">
          <DataField>SalesAmount</DataField>
          <rd:TypeName>Decimal</rd:TypeName>
        </Field>
        <Field Name="SalesTerritoryCountry">
          <DataField>SalesTerritoryCountry</DataField>
          <rd:TypeName>String</rd:TypeName>
        </Field>
      </Fields>
    </DataSet>
  </DataSets>
